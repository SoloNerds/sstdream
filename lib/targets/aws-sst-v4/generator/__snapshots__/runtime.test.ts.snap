  "src/workers/process-job.ts": "import { putItem } from "../../lib/dynamo";

/** SQS subscriber for the "ProcessJob" worker. */
export async function handler(event: { Records: { body: string }[] }) {
  for (const record of event.Records) {
    const message = JSON.parse(record.body) as Record<string, unknown>;
    console.log("Processing message", message);

    // TODO: replace with your processing logic
    await putItem({
      pk: \`job#\${message.id ?? "unknown"}\`,
      sk: new Date().toISOString(),
      ...message,
    });
  }
}
",
  "sst.config.ts": "/// <reference path="./.sst/platform/config.d.ts" />

export default $config({
  app(input) {
    return {
      name: "ai-processing-app",
      home: "aws",
      removal: input.stage === "production" ? "retain" : "remove",
      protect: input.stage === "production",
      providers: {
        aws: {
          region: "us-east-1",
        },
      },
    };
  },
  async run() {
    const uploads = new sst.aws.Bucket("Uploads");

    const appTable = new sst.aws.Dynamo("AppTable", {
      fields: {
        pk: "string",
        sk: "string",
      },
      primaryIndex: { hashKey: "pk", rangeKey: "sk" },
    });

    const jobs = new sst.aws.Queue("Jobs");

    jobs.subscribe({
      handler: "src/workers/process-job.handler",
      link: [appTable],
      timeout: "60 seconds",
    });

    const web = new sst.aws.Nextjs("Web", {
      path: ".",
      link: [uploads, jobs],
    });

    return {
      web: web.url,
      uploads: uploads.name,
      appTable: appTable.name,
      jobs: jobs.url,
    };
  },
});
",
