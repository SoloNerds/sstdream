// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`runtime code generator — AI Processing App > produces the full reference fileset (snapshot) 1`] = `
{
  "app/actions/create-upload-url.ts": ""use server";

import { createUploadUrl } from "../../lib/storage";

export async function getUploadUrl(filename: string, contentType?: string) {
  const key = \`uploads/\${Date.now()}-\${filename}\`;
  const url = await createUploadUrl(key, contentType);
  return { url, key };
}
",
  "app/actions/enqueue-job.ts": ""use server";

import { enqueue } from "../../lib/queue";

export async function enqueueJob(payload: Record<string, unknown>) {
  await enqueue(payload);
  return { queued: true };
}
",
  "lib/dynamo.ts": "import { Resource } from "sst";
import { DynamoDBClient } from "@aws-sdk/client-dynamodb";
import { DynamoDBDocumentClient, PutCommand, GetCommand } from "@aws-sdk/lib-dynamodb";

const client = DynamoDBDocumentClient.from(new DynamoDBClient({}));
const TableName = Resource.AppTable.name;

export async function putItem(item: Record<string, unknown>) {
  await client.send(new PutCommand({ TableName, Item: item }));
}

export async function getItem(key: { pk: string; sk: string }) {
  const result = await client.send(new GetCommand({ TableName, Key: key }));
  return result.Item;
}
",
  "lib/env.ts": "import { Resource } from "sst";

// Access linked SST resources anywhere in your app or functions.
// e.g. Resource.Uploads.name, Resource.Jobs.url, Resource.MySecret.value
export { Resource };
",
  "lib/queue.ts": "import { Resource } from "sst";
import { SQSClient, SendMessageCommand } from "@aws-sdk/client-sqs";

const sqs = new SQSClient({});

/** Send a JSON message to the queue. */
export async function enqueue(body: unknown) {
  await sqs.send(
    new SendMessageCommand({
      QueueUrl: Resource.Jobs.url,
      MessageBody: JSON.stringify(body),
    }),
  );
}
",
  "lib/storage.ts": "import { Resource } from "sst";
import { S3Client, PutObjectCommand } from "@aws-sdk/client-s3";
import { getSignedUrl } from "@aws-sdk/s3-request-presigner";

const s3 = new S3Client({});

/** Create a presigned PUT URL for uploading directly to the bucket. */
export async function createUploadUrl(key: string, contentType?: string) {
  const command = new PutObjectCommand({
    Bucket: Resource.Uploads.name,
    Key: key,
    ContentType: contentType,
  });
  return getSignedUrl(s3, command, { expiresIn: 3600 });
}
",
  "package.additions.json": "{
  "dependencies": {
    "sst": "latest",
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/s3-request-presigner": "latest",
    "@aws-sdk/client-sqs": "latest",
    "@aws-sdk/client-dynamodb": "latest",
    "@aws-sdk/lib-dynamodb": "latest"
  },
  "scripts": {
    "dev:sst": "sst dev",
    "deploy": "sst deploy",
    "remove": "sst remove"
  }
}
",
  "src/workers/process-job.ts": "import { putItem } from "../../lib/dynamo";

/** SQS subscriber for the "ProcessJob" worker. */
export async function handler(event: { Records: { body: string }[] }) {
  for (const record of event.Records) {
    const message = JSON.parse(record.body) as Record<string, unknown>;
    console.log("Processing message", message);

    // TODO: replace with your processing logic
    await putItem({
      pk: \`job#\${message.id ?? "unknown"}\`,
      sk: new Date().toISOString(),
      ...message,
    });
  }
}
",
  "sst.config.ts": "/// <reference path="./.sst/platform/config.d.ts" />

export default $config({
  app(input) {
    return {
      name: "ai-processing-app",
      home: "aws",
      removal: input.stage === "production" ? "retain" : "remove",
      protect: input.stage === "production",
      providers: {
        aws: {
          region: "us-east-1",
        },
      },
    };
  },
  async run() {
    const uploads = new sst.aws.Bucket("Uploads");

    const appTable = new sst.aws.Dynamo("AppTable", {
      fields: {
        pk: "string",
        sk: "string",
      },
      primaryIndex: { hashKey: "pk", rangeKey: "sk" },
    });

    const jobs = new sst.aws.Queue("Jobs");

    jobs.subscribe({
      handler: "src/workers/process-job.handler",
      link: [appTable],
      timeout: "60 seconds",
    });

    const web = new sst.aws.Nextjs("Web", {
      path: ".",
      link: [uploads, jobs],
    });

    return {
      web: web.url,
      uploads: uploads.name,
      appTable: appTable.name,
      jobs: jobs.url,
    };
  },
});
",
}
`;
